modules = ["python-3.11"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[workflows]

[[workflows.workflow]]
name = "Run"
mode = "sequential"
author = 55322737

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd unified-engine && python app.py"

[deployment]
run = ["sh", "-c", "cd unified-engine && python app.py"]
deploymentTarget = "cloudrun"
